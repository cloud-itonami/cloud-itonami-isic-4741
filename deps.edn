{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the kotoba-lang org of this workspace (transferred + renamed from
 ;; com-junkawasaki/langgraph-clj / com-junkawasaki/langchain-clj). This
 ;; repo is standalone (forkable outside the workspace); the :local/root
 ;; paths only resolve inside the monorepo checkout — a standalone fork
 ;; should override them with git coordinates.
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}
        io.github.kotoba-lang/robotics
        {:local/root "../../kotoba-lang/robotics"}
        ;; REAL engineering-simulation dependency (ADR-2607152000, extending
        ;; ADR-2607151600's automotive pilot to this vertical): techretail.
        ;; robotics's NEW simulate-drop-test now actually calls physics-2d's
        ;; real, tested world-step impulse/gravity solver -- a device rigid
        ;; body free-falls under real gravity onto a static test-surface
        ;; body, and a real, non-fabricated peak impact deceleration is read
        ;; directly off the simulated trajectory -- instead of comparing
        ;; static self-reported fields. No design-library sibling repo is
        ;; needed here (unlike automotive's kami-engine-vehicle-designer
        ;; pairing): this vertical's honest scope is the physics timestep
        ;; itself, built directly inside techretail.robotics.
        io.github.kotoba-lang/physics-2d
        {:git/url "https://github.com/kotoba-lang/physics-2d.git"
         :sha "03b6c23c8d9aa36b92a8130fd3e37fc2548b4d26"}
        ;; REAL CAD/BREP bridge (ADR-2607998500, closing out the
        ;; 6-vertical digital-twin wave ADR-2607160000 started, following
        ;; quarryops/isic-0810's own free-fall-physics precedent,
        ;; ADR-2607995500): techretail.cad now actually builds+tessellates
        ;; a BREP trade-in-device envelope via org-iso-10303's
        ;; brep.feature/brep.tessellate, the SAME kernel automotive's
        ;; vdesign.cad and autoparts's/fab's/quarryops's autoparts.cad/
        ;; fab.cad/quarryops.cad already depend on -- not a new CAD
        ;; kernel written for this actor. As with physics-2d above, this
        ;; vertical has no sibling design-library repo, so the dependency
        ;; is taken directly here rather than through a paired repo the
        ;; way automotive's kami-engine-vehicle-designer dependency
        ;; works. Deliberately NOT added: kotoba-lang/webgpu
        ;; (techretail.scene matches its kami.webgpu.mesh DATA shape
        ;; only -- that lib is .cljs-only, real GPU device/buffer calls,
        ;; unusable in this JVM/.cljc actor repo; see techretail.scene's
        ;; docstring for the same disclosed limitation vdesign.scene/
        ;; autoparts.scene/fab.scene/quarryops.scene document).
        io.github.kotoba-lang/org-iso-10303
        {:git/url "https://github.com/kotoba-lang/org-iso-10303.git"
         :sha "a1de3b075bcdcfbfb75c781eb88e3d07195831cf"}
        ;; shared langchain.db store seam (EDN-blob codec + identity
        ;; schema + field-spec entity helpers) -- the codec store.cljc
        ;; uses instead of hand-rolling enc/dec* (ADR-2607141600).
        io.github.kotoba-lang/langchain-store
        {:local/root "../../kotoba-lang/langchain-store"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "techretail.sim"]}
  :export {:main-opts ["-m" "techretail.export-run"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
